# ============================================================
# Agent-Ranger-2 — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ----------------------------------------------------------
# REQUIRED: Anthropic Claude API
# Get key at https://console.anthropic.com
# ----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude model to use (default is fine)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ----------------------------------------------------------
# REQUIRED: Neon PostgreSQL (free tier available)
# Get connection string at https://console.neon.tech
# ----------------------------------------------------------
VITE_DATABASE_URL=postgresql://neondb_owner:npg_xxxxx@ep-xxxxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_xxxxx@ep-xxxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ----------------------------------------------------------
# OPTIONAL: ElevenLabs Text-to-Speech
# Only needed if you want AI agents to speak out loud
# Get key at https://elevenlabs.io
# ----------------------------------------------------------
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
